# Production: canonical URL cho metadata / JSON-LD (Vercel), ví dụ https://your-site.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: Google Search Console verification meta content
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Cùng backend với app POS: EXPO_PUBLIC_API_URL (dev web có thể localhost; POS trên điện thoại thường cần IP máy chủ)
NEXT_PUBLIC_API_URL=http://localhost:5001
NEXT_PUBLIC_SALON_NAME=Nice Nails & Spa
NEXT_PUBLIC_SALON_TAGLINE=Professional nail care for ladies & gentlemen.
NEXT_PUBLIC_SALON_AREA=North Phoenix, AZ 85021
NEXT_PUBLIC_SALON_PHONE=(602) 759-9184
# Optional hero card copy (defaults match luxury banner)
# NEXT_PUBLIC_HERO_HEADLINE=Luxury Nails That Turn Heads
# NEXT_PUBLIC_HERO_SUBLINE=Top-rated nail salon in Phoenix · Book in 60 seconds
# NEXT_PUBLIC_HERO_SOCIAL_PROOF=4.9 rating · 650+ Google reviews
NEXT_PUBLIC_SALON_ADDRESS=8048 N 19th Ave, Phoenix, AZ 85021
NEXT_PUBLIC_SALON_HOURS=Mon–Sat 9:30 AM – 7:00 PM · Sun 10:00 AM – 4:00 PM
# Optional: override JSON-LD opening hours (array of { dayOfWeek, opens, closes })
# NEXT_PUBLIC_OPENING_HOURS_JSON=[{"dayOfWeek":["Monday","Tuesday"],"opens":"09:30","closes":"19:00"}]
# Optional: JSON-LD GeoCoordinates (defaults: 33.5722, -112.0901)
# NEXT_PUBLIC_SALON_LAT=33.5722
# NEXT_PUBLIC_SALON_LNG=-112.0901
NEXT_PUBLIC_SALON_MAPS_URL=https://maps.app.goo.gl/RxXkeYRL63uib95d6
# Optional: NailSalon JSON-LD (layout) — description, sameAs social URLs
# NEXT_PUBLIC_JSONLD_DESCRIPTION=
# NEXT_PUBLIC_SALON_FACEBOOK_URL=https://www.facebook.com/yourpage
# NEXT_PUBLIC_SALON_INSTAGRAM_URL=https://www.instagram.com/yourprofile
# Optional: paste the full embed URL from Google Maps → Share → Embed a map
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=
